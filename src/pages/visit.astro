---
import PageLayout from '../layouts/PageLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import site from '../data/site.json';

const { visit, phone, phoneDisplay, email, address, hours, social } = site;
const placeQuery = 'Paradise Valley Garden Nursery, Borne, Dominica';
const embedUrl = `https://maps.google.com/maps?q=${encodeURIComponent(placeQuery)}&z=16&output=embed`;
const mapUrl = site.mapsUrl;
---

<PageLayout
  title="Plan Your Visit"
  description="Visit Paradise Valley Garden & Nursery in Borne, St. John, Dominica. Open 7 days a week. Get directions, hours, and contact information."
  image="/images/pvalley.webp"
>
  <PageHeader
    title={visit.hero.title}
    subtitle={visit.hero.subtitle}
    image="/images/pvalley.webp"
  />

  <section class="section-padding">
    <div class="container-wide">
      <div class="visit-grid">
        <div class="visit-info reveal">
          <div class="info-card">
            <h2>Contact Us</h2>
            <ul class="contact-list">
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <div>
                  <strong>Address</strong>
                  <span>{address.display}</span>
                </div>
              </li>
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <div>
                  <strong>Phone</strong>
                  <a href={`tel:${phone}`}>{phoneDisplay}</a>
                </div>
              </li>
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <div>
                  <strong>Email</strong>
                  <a href={`mailto:${email}`}>{email}</a>
                </div>
              </li>
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                <div>
                  <strong>Instagram</strong>
                  <a href={social.instagram} target="_blank" rel="noopener noreferrer">@p.aradise_v.alley</a>
                </div>
              </li>
            </ul>
          </div>

          <div class="info-card">
            <h2>Opening Hours</h2>
            <ul class="hours-list">
              {hours.map((h) => (
                <li>
                  <span class="hours-days">{h.days}</span>
                  <span>{h.time}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="info-card">
            <h2>Visitor Tips</h2>
            <ul class="tips-list">
              {visit.tips.map((tip) => (
                <li>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  {tip}
                </li>
              ))}
            </ul>
          </div>

          <a href={mapUrl} class="btn" target="_blank" rel="noopener noreferrer">Get Directions</a>
        </div>

        <div class="visit-map reveal reveal-delay-2">
          <figure class="map-figure">
            <div class="map-wrap">
              <iframe
                src={embedUrl}
                title="Map showing Paradise Valley Garden & Nursery location in Borne, Dominica"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                allow="fullscreen"
              ></iframe>
            </div>
          </figure>
          <p class="directions-text">{visit.directions}</p>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .visit-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  .visit-info,
  .visit-map {
    min-width: 0;
  }

  .info-card {
    position: relative;
    isolation: isolate;
    background: var(--mist);
    padding: clamp(1.25rem, 3vw, 2rem);
    border-radius: var(--radius-lg);
    margin-bottom: 1.75rem;
  }

  /* Loose hand-drawn crayon frame around each block. */
  .info-card::before {
    content: '';
    position: absolute;
    z-index: -1;
    inset: -12px -14px -14px -10px;
    border: 2.5px solid var(--tropical-coral);
    border-radius: 20px 16px 22px 18px;
    transform: rotate(-0.7deg);
    opacity: 0.6;
    filter: var(--crayon-filter);
    pointer-events: none;
  }

  .info-card::after {
    content: '';
    position: absolute;
    z-index: -1;
    inset: -6px -7px -7px -5px;
    border: 2px solid var(--tropical-gold);
    border-radius: 16px 20px 15px 22px;
    transform: rotate(0.6deg);
    opacity: 0.45;
    filter: var(--crayon-filter);
    pointer-events: none;
  }

  .info-card h2 {
    font-size: 1.35rem;
    margin-bottom: 1.25rem;
  }

  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-list li {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    min-width: 0;
  }

  .contact-list li > div {
    min-width: 0;
  }

  .contact-list svg {
    flex-shrink: 0;
    color: var(--tropical-coral);
    margin-top: 2px;
  }

  .contact-list strong {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--forest-deep);
    margin-bottom: 0.2rem;
  }

  .contact-list span,
  .contact-list a {
    font-size: 0.95rem;
    color: var(--forest-medium);
    overflow-wrap: anywhere;
  }

  .contact-list a:hover { color: var(--tropical-coral); }

  .hours-list li {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.25rem 1rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    font-size: 0.95rem;
  }

  .hours-list li:last-child { border-bottom: none; }

  .hours-days {
    font-weight: 600;
    color: var(--forest-deep);
  }

  .tips-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .tips-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--forest-medium);
  }

  .tips-list svg {
    flex-shrink: 0;
    color: var(--tropical-coral);
    margin-top: 4px;
  }

  .visit-info .btn {
    display: flex;
    width: fit-content;
    max-width: 100%;
    text-align: center;
    margin: 0.75rem auto 0;
  }

  .map-figure {
    position: relative;
    isolation: isolate;
    margin: 0;
  }

  /* Loose hand-drawn crayon frame in garden green */
  .map-figure::before {
    content: '';
    position: absolute;
    z-index: -1;
    inset: -12px -14px -14px -10px;
    border: 2.5px solid var(--leaf);
    border-radius: 20px 16px 22px 18px;
    transform: rotate(-0.7deg);
    opacity: 0.65;
    filter: var(--crayon-filter);
    pointer-events: none;
  }

  .map-figure::after {
    content: '';
    position: absolute;
    z-index: -1;
    inset: -6px -7px -7px -5px;
    border: 2px solid var(--forest-light);
    border-radius: 16px 20px 15px 22px;
    transform: rotate(0.6deg);
    opacity: 0.5;
    filter: var(--crayon-filter);
    pointer-events: none;
  }

  .map-wrap {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    aspect-ratio: 4 / 3;
  }

  .map-wrap iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  .directions-text {
    margin-top: 1.25rem;
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--forest-light);
    margin-bottom: 0;
  }

  @media (max-width: 1024px) {
    .visit-grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  @media (max-width: 768px) {
    /* Give the button room from the Visitor Tips crayon box on mobile */
    .visit-info .btn {
      margin-top: 1.75rem;
    }
  }

  @media (max-width: 480px) {
    .map-wrap {
      aspect-ratio: 1;
    }
  }
</style>
