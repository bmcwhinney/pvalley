---
import { Picture } from 'astro:assets';
import PageLayout from '../layouts/PageLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CTABanner from '../components/CTABanner.astro';
import Decor from '../components/Decor.astro';
import site from '../data/site.json';
import { serviceIcons } from '../utils/icons';
import { img, widthsFor } from '../utils/images';

const { about } = site;
---

<PageLayout
  title="About Us"
  description="Learn about Paradise Valley Garden & Nursery — a 60-acre botanical sanctuary in Borne, Dominica with rare Anthuriums, resident peacocks, and a commitment to sustainability."
  image="/images/pval44.webp"
>
  <PageHeader
    title={about.hero.title}
    subtitle={about.hero.subtitle}
    image="/images/about-banner.webp"
  />

  {about.sections.map((section, i) => (
    <section class:list={['section-editorial section-rule', { 'bg-mist': i % 2 === 1 }]}>
      {i === 0 && (
        <Decor
          image="/images/decor/hibiscus.webp"
          width="clamp(110px, 14vw, 185px)"
          opacity={0.32}
          rotate="-6deg"
          position="bottom: 7%; left: -1.25rem;"
          hideMobile
        />
      )}
      <div class:list={['container-wide', 'content-grid', { 'content-grid--reverse': i % 2 === 1 }]}>
        <div>
          <h2>{section.title}</h2>
          <p>{section.content}</p>
        </div>
        <figure class="content-figure">
          <Picture
            src={img(section.image)}
            formats={['avif', 'webp']}
            fallbackFormat="webp"
            widths={widthsFor(img(section.image), [360, 540, 720])}
            sizes="(max-width: 900px) 92vw, 540px"
            quality={70}
            alt={section.imageAlt}
          />
        </figure>
      </div>
    </section>
  ))}

  <section class="section-editorial bg-mist section-rule values-section">
    <Decor
      image="/images/decor/hummingbird.webp"
      width="clamp(100px, 12vw, 160px)"
      opacity={0.16}
      rotate="4deg"
      position="top: 8%; right: -1rem;"
      hideMobile
    />
    <div class="container-wide values-inner">
      <div class="values-head">
        <p class="section-label">What guides us</p>
        <h2>The heart of Paradise Valley</h2>
        <p class="values-intro">More than a garden, we're a living community rooted in care — for the land, for our neighbours, and for everyone who wanders our paths.</p>
      </div>
      <div class="values-grid">
        {about.values.map((value) => (
          <article class="value-card">
            <span class="value-icon" aria-hidden="true">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={serviceIcons[value.icon]} />
            </span>
            <h3>{value.title}</h3>
            <p>{value.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    title="Come walk the grounds"
    description="Paradise Valley is open seven days a week. We'd love to show you around."
    buttonText="Plan your visit"
    buttonHref="/visit"
    decorImage="/images/decor/peacock-standing.webp"
    decorWidth="clamp(160px, 24vw, 280px)"
    decorOpacity={0.38}
    decorPosition="bottom: 0; right: 2%;"
    decor2Image="/images/decor/flowers-pink.webp"
    decor2Width="clamp(140px, 20vw, 230px)"
    decor2Opacity={0.38}
    decor2Rotate="-4deg"
    decor2Position="top: 50%; left: 2%; translate: 0 -50%;"
  />
</PageLayout>

<style>
  .section-editorial {
    position: relative;
    overflow: clip;
    isolation: isolate;
  }

  .content-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: center;
  }

  .content-grid--reverse .content-figure { order: -1; }

  .content-grid > div {
    text-align: center;
  }

  .content-grid h2 {
    font-size: clamp(1.85rem, 3.5vw, 2.35rem);
    font-weight: 500;
    margin-bottom: 1.25rem;
  }

  .content-grid p {
    max-width: 42ch;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 0;
  }

  .content-figure {
    position: relative;
    isolation: isolate;
    margin: 0;
    --crayon-1: var(--tropical-coral);
    --crayon-2: var(--tropical-gold);
  }

  .content-grid--reverse .content-figure {
    --crayon-1: var(--tropical-gold);
    --crayon-2: var(--tropical-coral);
  }

  /* Loose hand-drawn crayon outline */
  .content-figure::before {
    content: '';
    position: absolute;
    z-index: -1;
    inset: -11px -13px -13px -8px;
    border: 2.5px solid var(--crayon-1);
    border-radius: 22px 16px 20px 18px;
    transform: rotate(-1.4deg);
    opacity: 0.6;
    filter: var(--crayon-filter);
  }

  /* Second, offset stroke for a sketchy double-line feel */
  .content-figure::after {
    content: '';
    position: absolute;
    z-index: -1;
    inset: -5px -6px -6px -4px;
    border: 2px solid var(--crayon-2);
    border-radius: 16px 20px 15px 22px;
    transform: rotate(1deg);
    opacity: 0.45;
    filter: var(--crayon-filter);
  }

  .content-figure img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 14px;
    border: 5px solid var(--white);
    box-shadow: var(--shadow-md);
    transform: rotate(-1.2deg);
    transition: transform 0.45s var(--ease-spring);
  }

  .content-grid--reverse .content-figure img {
    transform: rotate(1.2deg);
  }

  .content-figure:hover img {
    transform: rotate(0deg) scale(1.015);
  }

  @media (prefers-reduced-motion: reduce) {
    .content-figure img {
      transition: none;
    }
  }

  .values-inner {
    position: relative;
    z-index: 1;
  }

  .values-head {
    max-width: 42rem;
    margin: 0 auto clamp(2.5rem, 5vw, 3.5rem);
    text-align: center;
  }

  .values-head h2 {
    font-size: clamp(1.85rem, 3.6vw, 2.5rem);
    font-weight: 500;
    margin-bottom: 1rem;
    text-wrap: balance;
  }

  .values-intro {
    margin: 0 auto;
    max-width: 52ch;
    color: var(--forest-light);
    line-height: 1.75;
    text-wrap: pretty;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(1.25rem, 2.5vw, 1.75rem);
  }

  .value-card {
    padding: clamp(1.6rem, 2.5vw, 2rem);
    background: var(--white);
    border: 1px solid rgba(18, 71, 52, 0.08);
    border-radius: 14px;
    text-align: center;
    transition: transform 0.35s ease, box-shadow 0.35s ease;
  }

  .value-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px -24px rgba(18, 71, 52, 0.45);
  }

  .value-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.25rem;
    height: 3.25rem;
    margin-bottom: 1.25rem;
    color: var(--leaf);
    background: rgba(18, 71, 52, 0.07);
    border-radius: 50%;
  }

  .value-card h3 {
    font-size: 1.2rem;
    font-weight: 500;
    margin: 0 0 0.6rem;
  }

  .value-card p {
    margin: 0;
    color: var(--forest-light);
    line-height: 1.7;
    font-size: 0.96rem;
  }

  @media (max-width: 900px) {
    .content-grid,
    .content-grid--reverse {
      grid-template-columns: minmax(0, 1fr);
    }

    .content-grid--reverse .content-figure {
      order: -1;
    }

    .values-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 540px) {
    .values-grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>
