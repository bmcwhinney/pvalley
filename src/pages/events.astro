---
import { Picture } from 'astro:assets';
import PageLayout from '../layouts/PageLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CTABanner from '../components/CTABanner.astro';
import site from '../data/site.json';
import { img, widthsFor } from '../utils/images';
---

<PageLayout
  title="Events"
  description="Join us at Paradise Valley Garden & Nursery for the annual Jazz & Arts festival and other celebrations in Dominica's botanical heartland."
  image="/images/jazzandarts.webp"
>
  <PageHeader
    title="Events"
    subtitle="Music, art, and gatherings in the garden."
    image="/images/events-banner.webp"
  />

  <section class="section-editorial">
    <div class="container-wide">
      {site.events.map((event) => (
        <article class="event-feature">
          <figure class="event-feature-img">
            <Picture
              src={img(event.image)}
              formats={['avif', 'webp']}
              fallbackFormat="webp"
              widths={widthsFor(img(event.image), [400, 600, 800])}
              sizes="(max-width: 900px) 92vw, 560px"
              alt={event.title}
            />
          </figure>
          <div class="event-feature-content">
            <p class="event-date">{event.day ? `${event.month} ${event.day}, ${event.year}` : `${event.month} ${event.year}`}</p>
            <h2>{event.title}</h2>
            <p class="event-lead">{event.description}</p>
            <p>{event.longDescription}</p>
            {event.highlights && (
              <ul class="event-highlights">
                {event.highlights.map((highlight) => (
                  <li>{highlight}</li>
                ))}
              </ul>
            )}
            <a href="/visit" class="text-link">Enquire about this event</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <CTABanner
    title="Host your event here"
    description="Weddings, celebrations, and private gatherings among the palms."
    buttonText="Enquire"
    buttonHref="/visit"
    decorImage="/images/decor/flowers-pink.webp"
    decorWidth="clamp(150px, 20vw, 235px)"
    decorOpacity={0.36}
    decorFlip={true}
    decorPosition="top: 50%; right: 1.5%; translate: 0 -50%;"
    decor2Image="/images/decor/flowers-blue.webp"
    decor2Width="clamp(140px, 18vw, 220px)"
    decor2Opacity={0.36}
    decor2Rotate="-4deg"
    decor2Position="top: 50%; left: 1.5%; translate: 0 -50%;"
  />
</PageLayout>

<style>
  .event-feature {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
    margin-bottom: 4rem;
  }

  .event-feature:last-child { margin-bottom: 0; }

  .event-feature-img {
    position: relative;
    isolation: isolate;
    margin: 0;
    --crayon-1: #f4c20d;
    --crayon-2: #e9a417;
  }

  /* Loose hand-drawn crayon frame in vibrant yellow */
  .event-feature-img::before {
    content: '';
    position: absolute;
    z-index: -1;
    inset: -11px -13px -13px -8px;
    border: 2.5px solid var(--crayon-1);
    border-radius: 22px 16px 20px 18px;
    transform: rotate(-1.2deg);
    opacity: 0.85;
    filter: var(--crayon-filter);
    pointer-events: none;
  }

  .event-feature-img::after {
    content: '';
    position: absolute;
    z-index: -1;
    inset: -5px -6px -6px -4px;
    border: 2px solid var(--crayon-2);
    border-radius: 16px 20px 15px 22px;
    transform: rotate(0.9deg);
    opacity: 0.65;
    filter: var(--crayon-filter);
    pointer-events: none;
  }

  .event-feature-img img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    border-radius: 14px;
    border: 5px solid var(--white);
    box-shadow: var(--shadow-md);
    transform: rotate(-1deg);
    transition: transform 0.45s var(--ease-spring);
  }

  .event-feature-img:hover img {
    transform: rotate(0deg) scale(1.01);
  }

  @media (prefers-reduced-motion: reduce) {
    .event-feature-img img {
      transition: none;
    }
  }

  .event-date {
    margin: 0 0 0.75rem;
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-style: italic;
    color: var(--tropical-coral);
  }

  .event-feature-content h2 {
    font-size: clamp(1.75rem, 4vw, 2.35rem);
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .event-lead {
    font-size: 1.02rem;
    font-weight: 500;
    color: var(--forest-deep);
    margin-bottom: 1rem;
  }

  .event-highlights {
    margin: 1.25rem 0 1.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
  }

  .event-highlights li {
    font-size: 0.9rem;
    color: var(--forest-light);
    list-style: none;
  }

  .event-highlights li::before {
    content: '·';
    color: var(--tropical-coral);
    margin-right: 0.35rem;
  }

  @media (max-width: 900px) {
    .event-feature {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>
