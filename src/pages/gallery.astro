---
import { Picture, getImage } from 'astro:assets';
import PageLayout from '../layouts/PageLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CTABanner from '../components/CTABanner.astro';
import site from '../data/site.json';
import { img, widthsFor } from '../utils/images';

const categories = [...new Set(site.gallery.map((item) => item.category))];
const countFor = (cat: string) => site.gallery.filter((i) => i.category === cat).length;

// Pre-generate a high-resolution WebP for each photo, used by the lightbox
// so the enlarged view is crisp rather than an upscaled thumbnail.
const fullImages = await Promise.all(
  site.gallery.map(async (item) => {
    const meta = img(item.src);
    const large = await getImage({
      src: meta,
      format: 'webp',
      width: Math.min(1200, meta.width),
      quality: 72,
    });
    return large.src;
  }),
);
---

<PageLayout
  title="Gallery"
  description="Explore photos of Paradise Valley Garden & Nursery — lush botanical grounds, resident peacocks, events, and tropical flora in Borne, Dominica."
  image="/images/pvalley.webp"
>
  <PageHeader
    title="Gallery"
    subtitle="Sixty acres of cultivated landscape, captured in season."
    image="/images/gallery-banner.webp"
  />

  <section class="section-editorial">
    <div class="container-wide">
      <div class="gallery-toolbar reveal">
        <div class="gallery-filters" role="tablist" aria-label="Filter gallery by category">
          <button class="filter-btn active" data-filter="all" data-label="All" role="tab" aria-selected="true">
            All <span class="filter-count">{site.gallery.length}</span>
          </button>
          {categories.map((cat) => (
            <button class="filter-btn" data-filter={cat.toLowerCase()} data-label={cat} role="tab" aria-selected="false">
              {cat} <span class="filter-count">{countFor(cat)}</span>
            </button>
          ))}
        </div>
        <p class="filter-status" id="filterStatus" aria-live="polite">Showing all {site.gallery.length} photos</p>
      </div>

      <div class="gallery-grid">
        {site.gallery.map((item, i) => (
          <figure
            class={`gallery-item reveal reveal-delay-${(i % 4) + 1}`}
            data-category={item.category.toLowerCase()}
          >
            <button
              class="gallery-img-wrap"
              data-lightbox
              data-full={fullImages[i]}
              type="button"
              aria-label={`View full size: ${item.alt}`}
            >
              <Picture
                src={img(item.src)}
                formats={['avif', 'webp']}
                fallbackFormat="webp"
                widths={widthsFor(img(item.src), [280, 400, 560, 720])}
                sizes="(max-width: 600px) 92vw, (max-width: 900px) 46vw, 320px"
                quality={68}
                alt={item.alt}
              />
              <div class="gallery-overlay">
                <span class="gallery-zoom">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
                </span>
              </div>
            </button>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Image preview">
    <button class="lightbox-close" aria-label="Close preview">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <button class="lightbox-nav lightbox-prev" id="lightboxPrev" aria-label="Previous image">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <img id="lightboxImg" src="" alt="" />
    <button class="lightbox-nav lightbox-next" id="lightboxNext" aria-label="Next image">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
    <span class="lightbox-counter" id="lightboxCounter" aria-hidden="true"></span>
  </div>

  <CTABanner
    title="See it in person"
    description="Photographs only go so far. The gardens are best experienced on foot."
    buttonText="Plan your visit"
    buttonHref="/visit"
    decorImage="/images/decor/peacock-fancy.webp"
    decorWidth="clamp(150px, 22vw, 240px)"
    decorOpacity={0.33}
    decorPosition="top: 50%; right: 1%; translate: 0 -50%;"
    decor2Image="/images/decor/hibiscus.webp"
    decor2Width="clamp(130px, 18vw, 210px)"
    decor2Opacity={0.34}
    decor2Rotate="-5deg"
    decor2Position="top: 50%; left: 1.5%; translate: 0 -50%;"
  />
</PageLayout>

<style>
  .gallery-toolbar {
    text-align: center;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .gallery-filters {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
    margin-bottom: 1rem;
  }

  .filter-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.2rem;
    min-height: 2.75rem;
    background: var(--white);
    border: 1px solid rgba(20, 54, 44, 0.14);
    border-radius: var(--radius-full);
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--forest-medium);
    cursor: pointer;
    transition: color var(--transition), border-color var(--transition), background var(--transition);
  }

  .filter-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.35rem;
    height: 1.35rem;
    padding: 0 0.35rem;
    border-radius: var(--radius-full);
    background: rgba(20, 54, 44, 0.08);
    color: var(--forest-light);
    font-size: 0.66rem;
    letter-spacing: 0;
    transition: background var(--transition), color var(--transition);
  }

  .filter-btn:hover {
    border-color: var(--tropical-coral);
    color: var(--forest-deep);
  }

  .filter-btn.active {
    background: var(--forest-deep);
    border-color: var(--forest-deep);
    color: var(--white);
    box-shadow: var(--shadow-sm);
  }

  .filter-btn.active .filter-count {
    background: rgba(255, 255, 255, 0.18);
    color: #ffffff;
  }

  .filter-status {
    font-size: 0.8rem;
    color: var(--forest-light);
    margin-bottom: 0;
  }

  /* Masonry columns — photos keep their natural aspect ratio */
  .gallery-grid {
    column-count: 3;
    column-gap: 1.25rem;
  }

  .gallery-item {
    break-inside: avoid;
    margin: 0 0 1.25rem;
    transition: opacity 0.35s var(--ease-out), transform 0.35s var(--ease-out);
  }

  .gallery-item.is-hidden {
    display: none;
  }

  .gallery-img-wrap {
    position: relative;
    display: block;
    width: 100%;
    border: none;
    padding: 0;
    cursor: zoom-in;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    background: none;
    transition: box-shadow var(--transition), transform var(--transition);
  }

  .gallery-img-wrap:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .gallery-img-wrap img {
    display: block;
    width: 100%;
    height: auto;
    transition: transform 0.55s var(--ease-out);
  }

  .gallery-img-wrap:hover img {
    transform: scale(1.05);
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(20, 54, 44, 0.55) 0%, rgba(20, 54, 44, 0.05) 55%);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--transition);
  }

  .gallery-img-wrap:hover .gallery-overlay,
  .gallery-img-wrap:focus-visible .gallery-overlay {
    opacity: 1;
  }

  @media (hover: none) {
    .gallery-overlay {
      opacity: 0;
    }

    .gallery-img-wrap img {
      transform: none;
    }
  }

  .gallery-zoom {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.18);
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
    border-radius: var(--radius-full);
    color: var(--white);
    transform: scale(0.85);
    transition: transform var(--transition);
  }

  .gallery-img-wrap:hover .gallery-zoom,
  .gallery-img-wrap:focus-visible .gallery-zoom {
    transform: scale(1);
  }

  @media (max-width: 900px) {
    .gallery-grid {
      column-count: 2;
      column-gap: 1rem;
    }

    .gallery-item {
      margin-bottom: 1rem;
    }
  }

  @media (max-width: 540px) {
    .gallery-grid {
      column-count: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-img-wrap:hover,
    .gallery-img-wrap:hover img {
      transform: none;
    }
  }
</style>
