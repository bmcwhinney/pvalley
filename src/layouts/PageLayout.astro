---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import QuickActions from '../components/QuickActions.astro';

interface Props {
  title: string;
  description: string;
  variant?: 'home' | 'inner';
  image?: string;
  showQuickActions?: boolean;
}

const { title, description, variant = 'inner', image, showQuickActions = false } = Astro.props;
const currentPath = Astro.url.pathname;
const quickActions = showQuickActions || currentPath.startsWith('/visit');
---

<BaseLayout title={title} description={description} image={image}>
  <slot name="head" slot="head" />
  <Nav variant={variant} currentPath={currentPath} />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
  <WhatsAppFloat />
  <BackToTop />
  {quickActions && <QuickActions />}
</BaseLayout>
