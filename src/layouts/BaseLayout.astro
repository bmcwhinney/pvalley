---
import { ViewTransitions } from 'astro:transitions';
import site from '../data/site.json';
import '@fontsource/nunito-sans/latin-400.css';
import '@fontsource/nunito-sans/latin-600.css';
import '@fontsource/nunito-sans/latin-700.css';
import '@fontsource/lora/latin-400.css';
import '@fontsource/lora/latin-500.css';
import '@fontsource/lora/latin-400-italic.css';
import '@fontsource/gochi-hand/latin-400.css';
import '../styles/global.css';
import '../styles/editorial.css';
import mainScriptUrl from '../scripts/main.js?url';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description, image = '/images/pvsocialshare.png' } = Astro.props;

const { name, url, email, phone, address, geo } = site;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const pageTitle = title === name ? `${name} | Botanical Garden & Nursery in Dominica` : `${title} | ${name}`;
const pageDescription = description ?? `Discover ${name} — a 60-acre botanical sanctuary in Borne, Dominica.`;
const ogImage = image.startsWith('http') ? image : `${url}${image}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={pageDescription} />
  <meta name="keywords" content="Paradise Valley Garden, nursery Dominica, botanical garden Dominica, Borne Dominica, scenic tours Dominica, wedding venue Dominica, Anthurium dominicense, tropical plants Caribbean, landscaping Dominica, Jazz and Arts Dominica" />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <meta name="author" content={name} />
  <meta name="theme-color" content="#14362c" />
  <link rel="canonical" href={canonicalURL} />

  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <meta name="geo.region" content="DM-06" />
  <meta name="geo.placename" content={address.display} />
  <meta name="geo.position" content={`${geo.latitude};${geo.longitude}`} />
  <meta name="ICBM" content={`${geo.latitude}, ${geo.longitude}`} />

  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={name} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:alt" content={`${name} — lush botanical gardens in Dominica`} />
  <meta property="og:locale" content="en_US" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDescription} />
  <meta name="twitter:image" content={ogImage} />

  <title>{pageTitle}</title>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebSite",
        "@id": `${url}/#website`,
        "url": url,
        "name": name,
        "publisher": { "@id": `${url}/#organization` },
        "inLanguage": "en"
      },
      {
        "@type": ["LocalBusiness", "GardenStore", "TouristAttraction"],
        "@id": `${url}/#organization`,
        "name": name,
        "url": url,
        "logo": `${url}/images/logo.png`,
        "telephone": phone,
        "email": email,
        "address": {
          "@type": "PostalAddress",
          "streetAddress": address.street,
          "addressLocality": address.locality,
          "addressRegion": address.region,
          "addressCountry": address.country
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": geo.latitude,
          "longitude": geo.longitude
        },
        "sameAs": ["https://www.instagram.com/p.aradise_v.alley"]
      }
    ]
  })} />

  <ViewTransitions />
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to content</a>
  <svg width="0" height="0" aria-hidden="true" focusable="false" style="position:absolute;width:0;height:0;overflow:hidden">
    <defs>
      <filter id="crayon-edge" x="-20%" y="-20%" width="140%" height="140%">
        <feTurbulence type="fractalNoise" baseFrequency="0.013 0.017" numOctaves="3" seed="7" result="noise" />
        <feDisplacementMap in="SourceGraphic" in2="noise" scale="9" xChannelSelector="R" yChannelSelector="G" />
      </filter>
    </defs>
  </svg>
  <slot />
  <script src={mainScriptUrl} defer></script>
</body>
</html>
