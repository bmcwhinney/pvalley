---
import { Image } from 'astro:assets';
import site from '../data/site.json';
import logo from '../assets/logo.png';
const { phone, phoneDisplay, email, address, hours, social, footerNav } = site;
---

<footer>
  <div class="container-wide footer-top">
    <div class="footer-brand">
      <a href="/">
        <Image src={logo} alt="Paradise Valley Garden & Nursery" class="footer-logo" widths={[220, 440]} sizes="220px" format="webp" loading="lazy" />
      </a>
      <p>Sixty acres of cultivated tropical landscape in Borne, St. John, open to visitors seven days a week.</p>
    </div>

    <nav class="footer-col" aria-label="Footer navigation">
      <h4>Explore</h4>
      <ul>
        {footerNav.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="footer-col">
      <h4>Contact</h4>
      <ul>
        <li>{address.display}</li>
        <li><a href={`tel:${phone}`}>{phoneDisplay}</a></li>
        <li><a href={`mailto:${email}`}>{email}</a></li>
        <li>
          <a href={social.instagram} class="footer-social" target="_blank" rel="noopener noreferrer">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            <span>Instagram</span>
          </a>
        </li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Hours</h4>
      <ul>
        {hours.map((h) => (
          <li><span class="hours-days">{h.days}</span> {h.time}</li>
        ))}
      </ul>
    </div>
  </div>

  <div class="container-wide footer-bottom">
    <p>&copy; 2026 Paradise Valley Garden & Nursery</p>
    <p class="site-credit">Site by <a href="https://www.satsuma.studio" target="_blank" rel="noopener noreferrer">Satsuma</a></p>
  </div>
</footer>

<style>
  footer {
    background: var(--forest-deep);
    color: rgba(255, 255, 255, 0.7);
    padding: clamp(3rem, 6vw, 4.5rem) 0 1.5rem;
    overflow-x: clip;
  }

  .footer-top {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) repeat(3, minmax(0, 1fr));
    gap: clamp(1.5rem, 4vw, 2.5rem);
    padding-bottom: clamp(2rem, 4vw, 3rem);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .footer-brand,
  .footer-col {
    min-width: 0;
  }

  .footer-brand a {
    display: inline-block;
    margin-bottom: 1.25rem;
  }

  .footer-logo {
    height: 60px;
    width: auto;
    max-width: 100%;
  }

  .footer-brand p {
    margin: 0;
    max-width: 28ch;
    font-size: 0.92rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.6);
  }

  .footer-col h4 {
    color: var(--tropical-gold);
    font-family: var(--font-script);
    font-size: 1.3rem;
    font-weight: 400;
    letter-spacing: 0.02em;
    margin-bottom: 1rem;
  }

  .footer-col ul {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .footer-col li {
    font-size: 0.9rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.65);
    overflow-wrap: anywhere;
  }

  .footer-col a {
    display: inline-flex;
    align-items: center;
    min-height: 2.5rem;
    color: rgba(255, 255, 255, 0.65);
    overflow-wrap: anywhere;
  }

  .footer-col a:hover {
    color: #ffffff;
  }

  .footer-social {
    gap: 0.45rem;
  }

  .footer-social svg {
    flex-shrink: 0;
  }

  .hours-days {
    display: block;
    color: rgba(255, 255, 255, 0.9);
    font-weight: 500;
  }

  .footer-bottom {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 0.75rem 2rem;
    padding-top: 1.5rem;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.4);
  }

  .footer-bottom p {
    margin: 0;
    color: rgba(255, 255, 255, 0.4);
  }

  .site-credit {
    grid-column: 2;
    justify-self: center;
    text-align: center;
  }

  .site-credit a {
    color: rgba(255, 255, 255, 0.45);
  }

  .site-credit a:hover {
    color: #ffffff;
  }

  /* Tablet: brand full-width, three equal columns below */
  @media (max-width: 960px) {
    .footer-top {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .footer-brand {
      grid-column: 1 / -1;
      max-width: 36rem;
    }
  }

  /* Small tablet / large phone: two columns for link groups */
  @media (max-width: 720px) {
    .footer-top {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2rem 1.5rem;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  /* Phone: single column, centered */
  @media (max-width: 520px) {
    .footer-top {
      grid-template-columns: 1fr;
      text-align: center;
      justify-items: center;
      gap: 2rem;
    }

    .footer-brand {
      max-width: none;
    }

    .footer-brand p {
      margin: 0 auto;
      max-width: 32ch;
    }

    .footer-col {
      width: 100%;
    }

    .footer-col ul {
      align-items: center;
    }

    .footer-bottom {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
    }

    .site-credit {
      grid-column: 1;
    }
  }
</style>
