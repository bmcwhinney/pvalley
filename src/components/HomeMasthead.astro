---
import site from '../data/site.json';
---

<div class="masthead" aria-label="At a glance">
  <div class="container-wide">
    <p class="masthead-lead">A working garden estate in the hills of Borne</p>

    <ul class="masthead-facts">
      {site.stats.map((stat) => (
        <li>
          <span class="masthead-value">{stat.suffix ? `${stat.value} ${stat.suffix}` : stat.value}</span>
          <span class="masthead-label">{stat.label}</span>
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  .masthead {
    background: var(--forest-deep);
    color: rgba(255, 255, 255, 0.8);
  }

  .masthead .container-wide {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.5fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
    padding-block: clamp(1.5rem, 3.5vw, 2rem);
  }

  .masthead-lead {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2.2vw, 1.35rem);
    font-style: italic;
    font-weight: 400;
    line-height: 1.4;
    color: #ffffff;
    max-width: 22ch;
  }

  .masthead-facts {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
  }

  .masthead-facts li {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
    padding: 0.15rem 1rem;
    border-left: 1px solid rgba(255, 255, 255, 0.14);
  }

  .masthead-facts li:first-child {
    padding-left: 0;
    border-left: none;
  }

  .masthead-value {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 2vw, 1.4rem);
    font-weight: 500;
    line-height: 1.1;
    color: #f0c14b;
    overflow-wrap: anywhere;
  }

  .masthead-label {
    font-size: clamp(0.75rem, 1.3vw, 0.84rem);
    line-height: 1.35;
    color: rgba(255, 255, 255, 0.65);
  }

  /* Tablet and below: stack lead, then 2×2 stats */
  @media (max-width: 900px) {
    .masthead .container-wide {
      grid-template-columns: minmax(0, 1fr);
      gap: 1.5rem;
    }

    .masthead-lead {
      max-width: none;
    }

    .masthead-facts {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1px;
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.12);
    }

    .masthead-facts li {
      padding: 1rem 1.1rem;
      border: none;
      background: var(--forest-deep);
    }

    .masthead-facts li:first-child {
      padding-left: 1.1rem;
    }
  }

  @media (max-width: 380px) {
    .masthead-facts li {
      padding: 0.9rem 0.85rem;
    }

    .masthead-facts li:first-child {
      padding-left: 0.85rem;
    }
  }
</style>
