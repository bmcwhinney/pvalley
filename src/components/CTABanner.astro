---
import Decor from './Decor.astro';

interface Props {
  title?: string;
  description?: string;
  buttonText?: string;
  buttonHref?: string;
  decorImage?: string;
  decorWidth?: string;
  decorOpacity?: number;
  decorRotate?: string;
  decorFlip?: boolean;
  decorPosition?: string;
  decor2Image?: string;
  decor2Width?: string;
  decor2Opacity?: number;
  decor2Rotate?: string;
  decor2Flip?: boolean;
  decor2Position?: string;
}

const {
  title = 'Plan a visit',
  description = 'Walk the grounds, browse the nursery, or enquire about hosting your next gathering among the palms.',
  buttonText = 'Visit us in Borne',
  buttonHref = '/visit',
  decorImage,
  decorWidth = 'clamp(130px, 20vw, 240px)',
  decorOpacity = 0.28,
  decorRotate = '0deg',
  decorFlip = false,
  decorPosition = 'top: 50%; right: -1.5rem; translate: 0 -50%;',
  decor2Image,
  decor2Width = 'clamp(130px, 20vw, 240px)',
  decor2Opacity = 0.28,
  decor2Rotate = '0deg',
  decor2Flip = false,
  decor2Position = 'top: 50%; left: -1.5rem; translate: 0 -50%;',
} = Astro.props;
---

<section class="cta-editorial section-rule">
  {decor2Image && (
    <Decor
      image={decor2Image}
      width={decor2Width}
      opacity={decor2Opacity}
      rotate={decor2Rotate}
      flip={decor2Flip}
      position={decor2Position}
      hideMobile
    />
  )}
  {decorImage && (
    <Decor
      image={decorImage}
      width={decorWidth}
      opacity={decorOpacity}
      rotate={decorRotate}
      flip={decorFlip}
      position={decorPosition}
      hideMobile
    />
  )}
  <div class="container-wide cta-layout">
    <div>
      <h2>{title}</h2>
      <p>{description}</p>
    </div>
    <a href={buttonHref} class="btn">{buttonText}</a>
  </div>
</section>

<style>
  .cta-editorial {
    padding: clamp(4rem, 8vw, 6rem) 0;
    background: var(--cream);
    position: relative;
    overflow: clip;
    isolation: isolate;
  }

  .cta-layout {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: clamp(1.5rem, 3vw, 2rem);
    max-width: 44rem;
    margin-inline: auto;
  }

  .cta-layout > div {
    min-width: 0;
  }

  .cta-layout h2 {
    font-family: var(--font-script);
    font-size: clamp(1.9rem, 3.8vw, 2.9rem);
    font-weight: 400;
    letter-spacing: 0.01em;
    line-height: 1.15;
    margin-bottom: 0.6rem;
    text-wrap: balance;
  }

  .cta-layout p {
    margin: 0 auto;
    max-width: 48ch;
    color: var(--forest-light);
    line-height: 1.7;
  }

  .cta-layout .btn {
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .cta-layout .btn {
      white-space: normal;
    }
  }
</style>
