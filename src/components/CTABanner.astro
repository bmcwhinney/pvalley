---
import Decor from './Decor.astro';

interface Props {
  title?: string;
  description?: string;
  buttonText?: string;
  buttonHref?: string;
  decorImage?: string;
  decorWidth?: string;
  decorOpacity?: number;
  decorRotate?: string;
  decorFlip?: boolean;
  decorPosition?: string;
}

const {
  title = 'Plan a visit',
  description = 'Walk the grounds, browse the nursery, or enquire about hosting your next gathering among the palms.',
  buttonText = 'Visit us in Borne',
  buttonHref = '/visit',
  decorImage,
  decorWidth = 'clamp(130px, 20vw, 240px)',
  decorOpacity = 0.13,
  decorRotate = '0deg',
  decorFlip = false,
  decorPosition = 'top: 50%; right: -1.5rem; translate: 0 -50%;',
} = Astro.props;
---

<section class="cta-editorial section-rule">
  {decorImage && (
    <Decor
      image={decorImage}
      width={decorWidth}
      opacity={decorOpacity}
      rotate={decorRotate}
      flip={decorFlip}
      position={decorPosition}
      hideMobile
    />
  )}
  <div class="container-wide cta-layout">
    <div>
      <h2>{title}</h2>
      <p>{description}</p>
    </div>
    <a href={buttonHref} class="btn">{buttonText}</a>
  </div>
</section>

<style>
  .cta-editorial {
    padding: clamp(4rem, 8vw, 6rem) 0;
    background: var(--cream);
    position: relative;
    overflow: clip;
    isolation: isolate;
  }

  .cta-layout {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: clamp(1.5rem, 4vw, 3rem);
  }

  .cta-layout > div {
    min-width: 0;
  }

  .cta-layout h2 {
    font-size: clamp(1.65rem, 3.5vw, 2.5rem);
    font-weight: 500;
    margin-bottom: 0.75rem;
    max-width: 16ch;
  }

  .cta-layout p {
    margin: 0;
    max-width: 40ch;
    color: var(--forest-light);
    line-height: 1.7;
  }

  .cta-layout .btn {
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .cta-layout {
      flex-direction: column;
      align-items: flex-start;
    }

    .cta-layout h2 {
      max-width: none;
    }

    .cta-layout .btn {
      width: 100%;
      white-space: normal;
    }
  }
</style>
