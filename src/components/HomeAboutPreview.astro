---
import { Picture } from 'astro:assets';
import Decor from './Decor.astro';
import { img, widthsFor } from '../utils/images';

const peacock = img('/images/peacock-perch.webp');
---

<section class="section-editorial section-rule about-section">
  <Decor
    image="/images/decor/hummingbird.webp"
    width="clamp(95px, 11vw, 165px)"
    opacity={0.34}
    rotate="-4deg"
    position="bottom: 6%; left: -1.5rem;"
    hideMobile
  />
  <div class="container-wide about-layout">
    <div class="about-copy">
      <p class="section-label">The garden</p>
      <h2>Cultivating nature in Borne</h2>
      <p class="pull-quote">More than a nursery — a place where Dominica's botanical heritage is lived in, every day.</p>
      <p>Take a walk through our masterfully curated horticulture garden and nursery as you feast your senses on the sights, sounds, and beauty of nature. Our venue is also a unique world-class destination for your special occasion.</p>
      <a href="/about" class="text-link">Read our story</a>
    </div>
    <figure class="about-figure">
      <div class="about-figure-media">
        <Picture
          src={peacock}
          formats={['avif', 'webp']}
          fallbackFormat="webp"
          widths={widthsFor(peacock, [360, 540])}
          sizes="(max-width: 900px) 92vw, 560px"
          quality={70}
          alt="A resident peacock in full plumage among the tropical foliage"
        />
      </div>
      <figcaption>A resident peacock among the gardens, Borne</figcaption>
    </figure>
  </div>
</section>

<style>
  .about-section {
    position: relative;
    overflow: clip;
    isolation: isolate;
  }

  .about-layout {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
    gap: clamp(2rem, 8vw, 7rem);
    align-items: start;
  }

  .about-copy,
  .about-figure {
    min-width: 0;
  }

  .about-copy h2 {
    font-family: var(--font-script);
    font-size: clamp(2.4rem, 4.8vw, 3.6rem);
    font-weight: 400;
    letter-spacing: 0.01em;
    line-height: 1.15;
    margin-bottom: 0.5rem;
    max-width: 16ch;
  }

  .about-copy > p:not(.pull-quote):not(.section-label) {
    max-width: 42ch;
    margin-bottom: 1.5rem;
  }

  .about-figure {
    margin: 0;
    position: relative;
  }

  .about-figure-media {
    position: relative;
    isolation: isolate;
    --crayon-1: var(--tropical-coral);
    --crayon-2: var(--tropical-gold);
  }

  /* Loose hand-drawn crayon frame around the photo */
  .about-figure-media::before {
    content: '';
    position: absolute;
    z-index: -1;
    inset: -11px -13px -13px -8px;
    border: 2.5px solid var(--crayon-1);
    border-radius: 22px 16px 20px 18px;
    transform: rotate(-1.2deg);
    opacity: 0.6;
    filter: var(--crayon-filter);
    pointer-events: none;
  }

  .about-figure-media::after {
    content: '';
    position: absolute;
    z-index: -1;
    inset: -5px -6px -6px -4px;
    border: 2px solid var(--crayon-2);
    border-radius: 16px 20px 15px 22px;
    transform: rotate(0.9deg);
    opacity: 0.45;
    filter: var(--crayon-filter);
    pointer-events: none;
  }

  .about-figure-media img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 14px;
    border: 5px solid var(--white);
    box-shadow: var(--shadow-md);
    transform: rotate(-1deg);
    transition: transform 0.45s var(--ease-spring);
  }

  .about-figure:hover .about-figure-media img {
    transform: rotate(0deg) scale(1.01);
  }

  .about-figure figcaption {
    margin-top: 1.35rem;
    font-size: 0.8rem;
    color: var(--forest-light);
    font-style: italic;
  }

  @media (prefers-reduced-motion: reduce) {
    .about-figure-media img {
      transition: none;
    }
  }

  @media (max-width: 900px) {
    .about-layout {
      grid-template-columns: minmax(0, 1fr);
    }

    .about-copy h2 {
      max-width: none;
    }

    .about-figure-media img {
      aspect-ratio: 1 / 1;
      object-position: center 40%;
    }
  }
</style>
