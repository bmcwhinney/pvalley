---
import { Picture } from 'astro:assets';
import bgImg from '../assets/images/pvalley.webp';
---

<section class="philosophy">
  <div class="philosophy-bg" aria-hidden="true">
    <Picture
      src={bgImg}
      formats={['avif', 'webp']}
      fallbackFormat="webp"
      widths={[640, 960, 1280, 1400]}
      sizes="100vw"
      alt=""
    />
  </div>
  <div class="philosophy-inner container-wide">
    <blockquote>
      <p>We believe a garden should give back, to the land, to the community, and to everyone who walks its paths.</p>
    </blockquote>
    <p class="philosophy-body">Locally sourced plants, endemic species propagation, and a commitment to sustainable practice across Dominica's Nature Island.</p>
    <a href="/about" class="text-link text-link--light">Our Approach</a>
  </div>
</section>

<style>
  .philosophy {
    position: relative;
    padding: clamp(5rem, 12vw, 9rem) 0;
    color: var(--white);
    overflow: hidden;
  }

  .philosophy-bg {
    position: absolute;
    inset: 0;
  }

  .philosophy-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .philosophy-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(12, 40, 30, 0.82);
  }

  .philosophy-inner {
    position: relative;
    z-index: 1;
    max-width: 54rem;
    margin-inline: auto;
    text-align: center;
  }

  blockquote {
    margin: 0 0 1.75rem;
  }

  blockquote p {
    margin: 0;
    font-family: var(--font-script);
    font-size: clamp(1.6rem, 3.4vw, 2.4rem);
    font-weight: 400;
    font-style: normal;
    letter-spacing: 0.01em;
    line-height: 1.45;
    color: var(--white);
  }

  .philosophy-body {
    margin: 0 auto 2rem;
    font-size: 1.02rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.78);
    max-width: 52ch;
  }

</style>
