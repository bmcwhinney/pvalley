---
import { Picture } from 'astro:assets';
import heroImg from '../assets/images/pvalley.webp';
---

<header class="hero">
  <div class="hero-bg" aria-hidden="true">
    <Picture
      src={heroImg}
      formats={['avif', 'webp']}
      fallbackFormat="webp"
      widths={[480, 640, 960, 1280]}
      sizes="100vw"
      quality={70}
      alt=""
      loading="eager"
      fetchpriority="high"
    />
  </div>
  <div class="hero-overlay" aria-hidden="true"></div>
  <div class="container-wide hero-inner">
    <div class="hero-content">
      <p class="hero-kicker">Paradise Valley · Borne, Dominica</p>
      <h1>A <em>lush oasis</em> in the heart of the Nature Island</h1>
      <p class="hero-lead">Sixty acres of rare tropical flora, riverside trails, and the quiet grandeur of a garden cultivated for generations.</p>
      <div class="hero-actions">
        <a href="/about" class="btn btn-hero">Explore the gardens</a>
        <a href="/visit" class="btn btn-hero-outline">Plan your visit</a>
      </div>
    </div>
  </div>
</header>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding: calc(var(--nav-height) + 1.5rem) 0 3rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(
        to right,
        rgba(8, 28, 20, 0.78) 0%,
        rgba(8, 28, 20, 0.58) 42%,
        rgba(8, 28, 20, 0.28) 100%
      ),
      linear-gradient(
        to bottom,
        rgba(8, 28, 20, 0.42) 0%,
        rgba(8, 28, 20, 0.58) 45%,
        rgba(8, 28, 20, 0.78) 100%
      );
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    width: 100%;
  }

  .hero-content {
    max-width: 42rem;
    color: #ffffff;
  }

  .hero-kicker {
    margin: 0 0 1.1rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.35);
  }

  .hero-content h1 {
    color: #ffffff !important;
    font-family: var(--font-script);
    font-size: clamp(2.75rem, 7.5vw, 4.75rem);
    font-weight: 400;
    letter-spacing: 0.01em;
    line-height: 1.15;
    margin-bottom: 1.25rem;
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.45);
  }

  .hero-content h1 em {
    font-style: normal;
    font-weight: 400;
    color: #f0c14b;
  }

  .hero-lead {
    margin: 0 0 2rem;
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.95) !important;
    max-width: 36rem;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.35);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1.75rem, 4vw, 3rem);
  }

  .btn-hero,
  .btn-hero-outline {
    color: #ffffff;
    --btn-ink: #ffffff;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.35);
  }

  .btn-hero:hover,
  .btn-hero-outline:hover {
    color: #f0c14b;
  }

  .btn-hero:hover::before,
  .btn-hero-outline:hover::before {
    border-color: #f0c14b;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 100svh;
      align-items: flex-end;
      padding-bottom: 2.5rem;
    }

    .hero-overlay {
      background:
        linear-gradient(
          to top,
          rgba(8, 28, 20, 0.86) 0%,
          rgba(8, 28, 20, 0.66) 42%,
          rgba(8, 28, 20, 0.38) 100%
        ),
        linear-gradient(
          to right,
          rgba(8, 28, 20, 0.42) 0%,
          rgba(8, 28, 20, 0.22) 100%
        );
    }

    .hero-actions {
      flex-direction: column;
      align-items: flex-start;
      gap: clamp(1.25rem, 3.5vw, 1.85rem);
    }

    .hero-actions .btn {
      width: auto;
      max-width: 100%;
    }
  }
</style>
