---
---

<header class="hero">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="hero-overlay" aria-hidden="true"></div>
  <div class="container-wide hero-inner">
    <div class="hero-content">
      <p class="hero-kicker">Paradise Valley · Borne, Dominica</p>
      <h1>A <em>lush oasis</em> in the heart of the Nature Island</h1>
      <p class="hero-lead">Sixty acres of rare tropical flora, riverside trails, and the quiet grandeur of a garden cultivated for generations.</p>
      <div class="hero-actions">
        <a href="/about" class="btn btn-hero">Explore the gardens</a>
        <a href="/visit" class="btn btn-hero-outline">Plan your visit</a>
      </div>
    </div>
  </div>
</header>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding: calc(var(--nav-height) + 1.5rem) 0 3rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: url('/images/pvalley.jpg') center / cover no-repeat;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(
        to right,
        rgba(8, 28, 20, 0.78) 0%,
        rgba(8, 28, 20, 0.58) 42%,
        rgba(8, 28, 20, 0.28) 100%
      ),
      linear-gradient(
        to bottom,
        rgba(8, 28, 20, 0.42) 0%,
        rgba(8, 28, 20, 0.58) 45%,
        rgba(8, 28, 20, 0.78) 100%
      );
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    width: 100%;
  }

  .hero-content {
    max-width: 42rem;
    color: #ffffff;
  }

  .hero-kicker {
    margin: 0 0 1rem;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: rgba(255, 255, 255, 0.9);
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.35);
  }

  .hero-content h1 {
    color: #ffffff !important;
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    font-weight: 500;
    line-height: 1.1;
    margin-bottom: 1.25rem;
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.45);
  }

  .hero-content h1 em {
    font-style: italic;
    font-weight: 400;
    color: #f0c14b;
  }

  .hero-lead {
    margin: 0 0 2rem;
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.95) !important;
    max-width: 36rem;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.35);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .btn-hero {
    background: #ffffff;
    color: var(--forest-deep);
    border-color: #ffffff;
  }

  .btn-hero:hover {
    background: var(--tropical-coral);
    border-color: var(--tropical-coral);
    color: #ffffff;
  }

  .btn-hero-outline {
    background: transparent;
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.55);
  }

  .btn-hero-outline:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: #ffffff;
    color: #ffffff;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 88svh;
      align-items: flex-end;
      padding-bottom: 2.5rem;
    }

    .hero-overlay {
      background:
        linear-gradient(
          to top,
          rgba(8, 28, 20, 0.86) 0%,
          rgba(8, 28, 20, 0.66) 42%,
          rgba(8, 28, 20, 0.38) 100%
        ),
        linear-gradient(
          to right,
          rgba(8, 28, 20, 0.42) 0%,
          rgba(8, 28, 20, 0.22) 100%
        );
    }

    .hero-actions {
      flex-direction: column;
    }

    .hero-actions .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
