---
import { Picture } from 'astro:assets';
import Breadcrumbs from './Breadcrumbs.astro';
import { img, widthsFor } from '../utils/images';

interface Props {
  title: string;
  subtitle?: string;
  image?: string;
  breadcrumbLabel?: string;
}

const {
  title,
  subtitle,
  image = '/images/pvalley.webp',
  breadcrumbLabel,
} = Astro.props;

const headerImg = img(image);
const headerWidths = widthsFor(headerImg, [480, 640, 960, 1200]);

const crumbs = [
  { label: 'Home', href: '/' },
  { label: breadcrumbLabel ?? title },
];
---

<header class="page-header">
  <div class="page-header-bg" aria-hidden="true">
    <Picture
      src={headerImg}
      formats={['avif', 'webp']}
      fallbackFormat="webp"
      widths={headerWidths}
      sizes="100vw"
      quality={70}
      alt=""
      loading="eager"
      fetchpriority="high"
    />
  </div>
  <div class="page-header-vignette" aria-hidden="true"></div>
  <div class="container-wide page-header-content">
    <Breadcrumbs items={crumbs} />
    <h1>{title}</h1>
    {subtitle && <p class="page-header-subtitle">{subtitle}</p>}
  </div>
</header>

<style>
  .page-header {
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    min-height: clamp(240px, 42vh, 420px);
    padding: calc(var(--nav-height) + 1.5rem) 0 clamp(2rem, 4vw, 3rem);
    overflow: hidden;
  }

  .page-header-bg {
    position: absolute;
    inset: 0;
  }

  .page-header-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
  }

  .page-header-vignette {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(12, 40, 30, 0.9) 0%, rgba(12, 40, 30, 0.45) 100%);
  }

  .page-header-content {
    position: relative;
    z-index: 1;
    color: var(--white);
    max-width: min(40rem, 100%);
    min-width: 0;
    margin-inline: auto;
    text-align: center;
  }

  .page-header :global(.breadcrumbs) {
    justify-content: center;
  }

  .page-header h1 {
    color: var(--white);
    font-family: var(--font-script);
    font-size: clamp(2.4rem, 7vw, 4.5rem);
    font-weight: 400;
    letter-spacing: 0.01em;
    margin-bottom: 0.75rem;
    line-height: 1.15;
    overflow-wrap: anywhere;
    text-wrap: balance;
  }

  .page-header-subtitle {
    color: rgba(255, 255, 255, 0.82);
    font-size: clamp(0.95rem, 2.2vw, 1.05rem);
    margin: 0 auto;
    line-height: 1.7;
    max-width: min(42ch, 100%);
    overflow-wrap: break-word;
  }

  @media (max-width: 480px) {
    .page-header {
      min-height: 220px;
      padding-bottom: 1.75rem;
    }
  }
</style>
