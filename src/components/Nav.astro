---
import site from '../data/site.json';

interface Props {
  variant?: 'home' | 'inner';
  currentPath?: string;
}

const { variant = 'home', currentPath = '/' } = Astro.props;
const { nav, phone, phoneDisplay, email, address } = site;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<div class="nav-overlay" id="navOverlay" aria-hidden="true"></div>

<nav id="navbar" class:list={[{ 'nav--inner': variant === 'inner' }]} aria-label="Main navigation">
  <div class="nav-inner">
    <a href="/" class="nav-logo-link" aria-label="Paradise Valley — Home">
      <img src="/images/logo.png" alt="Paradise Valley Garden & Nursery" class="logo-img" width="400" height="109" />
    </a>

    <button class="menu-toggle" id="menuBtn" aria-label="Open navigation menu" aria-expanded="false" aria-controls="navLinks">
      <span class="hamburger" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>

    <div class="nav-links" id="navLinks">
      <button class="menu-toggle menu-close" aria-label="Close navigation menu">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>

      {nav.map((item, i) => (
        <a
          href={item.href}
          class:list={['nav-link', { 'nav-cta': item.cta, 'nav-link--active': isActive(item.href) }]}
          aria-current={isActive(item.href) ? 'page' : undefined}
          style={`--i: ${i}`}
        >
          {item.label}
        </a>
      ))}

      <div class="nav-contact-info">
        <a href={`https://maps.google.com/?q=${encodeURIComponent(address.display)}`} target="_blank" rel="noopener noreferrer">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          {address.display}
        </a>
        <a href={`tel:${phone}`}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {phoneDisplay}
        </a>
        <a href={`mailto:${email}`}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          {email}
        </a>
      </div>

      <img src="/images/peacock.jpg" alt="" class="nav-peacock" loading="lazy" decoding="async" width="120" height="80" />
    </div>
  </div>
</nav>

<style>
  .nav-overlay {
    position: fixed;
    inset: 0;
    z-index: 998;
    background: rgba(10, 25, 20, 0.6);
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s var(--ease-out), visibility 0.4s;
  }

  .nav-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    padding: 0.85rem 0;
    z-index: 1000;
    transition:
      background 0.4s var(--ease-out),
      box-shadow 0.4s var(--ease-out),
      transform 0.35s var(--ease-out);
    background: transparent;
  }

  nav.nav--hidden {
    transform: translateY(-100%);
  }

  nav.nav--inner,
  nav.scrolled {
    background: rgba(18, 71, 52, 0.96);
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.12);
  }

  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    max-width: 100%;
    margin: 0;
    padding-inline: clamp(1.25rem, 3vw, 2.5rem);
  }

  .logo-img {
    height: clamp(42px, 4.5vw, 58px);
    width: auto;
    max-width: min(58vw, 260px);
    object-fit: contain;
    transition: height 0.35s var(--ease-out), opacity var(--transition);
  }

  .nav-logo-link {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    min-width: 0;
  }

  .nav-logo-link:hover .logo-img {
    opacity: 0.9;
  }

  nav.scrolled .logo-img,
  nav.nav--inner .logo-img {
    height: clamp(38px, 3.8vw, 48px);
  }

  @media (max-width: 400px) {
    .logo-img {
      height: 40px;
      max-width: 62vw;
    }
  }

  .nav-links {
    display: flex;
    gap: clamp(0.4rem, 1.4vw, 1.4rem);
    align-items: center;
  }

  .nav-link {
    color: rgba(255, 255, 255, 0.9);
    font-size: clamp(0.95rem, 1vw, 1.05rem);
    font-weight: 500;
    letter-spacing: 0.005em;
    position: relative;
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 0.6rem;
    white-space: nowrap;
  }

  .nav-link:not(.nav-cta)::after {
    content: '';
    position: absolute;
    width: 0;
    height: 2px;
    bottom: 0.35rem;
    left: 0.6rem;
    background-color: var(--tropical-coral);
    border-radius: 1px;
    transition: width 0.3s var(--ease-out);
  }

  .nav-link:not(.nav-cta):hover::after,
  .nav-link:not(.nav-cta).nav-link--active::after {
    width: calc(100% - 1.2rem);
  }

  .nav-link:hover,
  .nav-link--active { color: var(--white); }

  /* Visit CTA — explicit sizing so link styles never collapse it */
  .nav-link.nav-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.5rem;
    padding: 0.5rem 1.3rem;
    margin-left: 0.35rem;
    font-size: clamp(0.95rem, 1vw, 1.05rem);
    font-weight: 600;
    line-height: 1;
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: var(--radius);
    background: transparent;
    white-space: nowrap;
    flex-shrink: 0;
    transition:
      background var(--transition),
      border-color var(--transition),
      color var(--transition),
      transform var(--transition);
  }

  .nav-link.nav-cta:hover,
  .nav-link.nav-cta.nav-link--active {
    background: var(--tropical-coral);
    border-color: var(--tropical-coral);
    color: var(--white);
    transform: translateY(-1px);
  }

  /* Hamburger */
  .menu-toggle {
    display: none;
    color: white;
    cursor: pointer;
    z-index: 1002;
    background: none;
    border: none;
    padding: 0.5rem;
    line-height: 1;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
  }

  .hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 22px;
  }

  .hamburger span {
    display: block;
    height: 2px;
    background: var(--white);
    border-radius: 2px;
    transition: transform 0.3s var(--ease-out), opacity 0.3s;
  }

  .menu-toggle.is-open .hamburger span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .menu-toggle.is-open .hamburger span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.is-open .hamburger span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .nav-peacock,
  .nav-contact-info { display: none; }

  .menu-close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    display: none;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    transition: background var(--transition);
  }

  .menu-close:hover { background: rgba(255, 255, 255, 0.15); }

  @media (max-width: 1100px) {
    .menu-toggle { display: flex; }

    .nav-contact-info {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
      margin-top: 1.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    .nav-contact-info a {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      max-width: 100%;
      color: rgba(255, 255, 255, 0.55);
      font-size: 0.75rem;
      letter-spacing: 0.5px;
      font-weight: 400;
      text-transform: none;
      text-align: center;
      overflow-wrap: anywhere;
    }

    .nav-contact-info a:hover { color: var(--white); }
    .nav-contact-info svg { flex-shrink: 0; color: var(--tropical-coral); }

    .nav-peacock {
      display: none;
    }

    .nav-links.active .menu-close { display: flex; }
    body.menu-open #menuBtn { visibility: hidden; }

    .nav-links {
      position: fixed;
      top: 0;
      right: -100%;
      width: min(88%, 380px);
      height: 100vh;
      height: 100dvh;
      background: var(--forest-deep);
      flex-direction: column;
      justify-content: flex-start;
      align-items: center;
      gap: 0;
      overflow-y: auto;
      overscroll-behavior: contain;
      -webkit-overflow-scrolling: touch;
      transition: right 0.45s var(--ease-out);
      box-shadow: -8px 0 40px rgba(0, 0, 0, 0.25);
      padding: 4.5rem 1.5rem calc(2rem + env(safe-area-inset-bottom, 0px));
    }

    .nav-links.active { right: 0; }

    .nav-links .nav-link:not(.nav-cta) {
      font-size: 1rem;
      padding: 0.85rem 0;
      opacity: 0;
      transform: translateX(20px);
      transition:
        opacity 0.35s var(--ease-out),
        transform 0.35s var(--ease-out),
        color var(--transition);
      transition-delay: calc(var(--i) * 0.05s + 0.1s);
    }

    .nav-links .nav-link.nav-cta {
      width: min(100%, 16rem);
      min-height: 3rem;
      margin-top: 1.25rem;
      padding: 0.85rem 1.5rem;
      font-size: 1rem;
      opacity: 0;
      transform: translateX(20px);
      transition:
        opacity 0.35s var(--ease-out),
        transform 0.35s var(--ease-out),
        background var(--transition),
        border-color var(--transition),
        color var(--transition);
      transition-delay: calc(var(--i) * 0.05s + 0.1s);
    }

    .nav-links.active .nav-link:not(.nav-cta),
    .nav-links.active .nav-link.nav-cta {
      opacity: 1;
      transform: translateX(0);
    }

    .nav-links.active .nav-link.nav-cta:hover,
    .nav-links.active .nav-link.nav-cta.nav-link--active {
      transform: none;
    }
  }

  /* Mid desktop: tighten spacing so the row never overflows */
  @media (min-width: 1101px) and (max-width: 1240px) {
    .nav-links {
      gap: 0.2rem;
    }

    .nav-link {
      font-size: 0.95rem;
      padding-inline: 0.45rem;
    }

    .nav-link.nav-cta {
      min-height: 2.4rem;
      padding: 0.45rem 1.05rem;
      font-size: 0.95rem;
      margin-left: 0.35rem;
    }
  }
</style>
