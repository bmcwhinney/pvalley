---
import { Picture } from 'astro:assets';
import site from '../data/site.json';
import { img, widthsFor } from '../utils/images';
const event = site.events[0];
const eventImg = img(event.image);
---

<section class="section-editorial section-rule">
  <div class="container-wide event-layout">
    <figure class="event-figure">
      <Picture
        src={eventImg}
        formats={['avif', 'webp']}
        fallbackFormat="webp"
        widths={widthsFor(eventImg, [360, 540, 720])}
        sizes="(max-width: 900px) 92vw, 620px"
        quality={70}
        alt={event.title}
      />
    </figure>
    <div class="event-copy">
      <p class="section-label">Coming up</p>
      <p class="event-date">{event.day ? `${event.month} ${event.day}, ${event.year}` : `${event.month} ${event.year}`}</p>
      <h2>{event.title}</h2>
      <p>{event.description}</p>
      <a href="/events" class="text-link">Event details</a>
    </div>
  </div>
</section>

<style>
  .event-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: center;
  }

  .event-figure {
    position: relative;
    isolation: isolate;
    margin: 0;
    --crayon-1: #f4c20d;
    --crayon-2: #e9a417;
  }

  /* Loose hand-drawn crayon frame in vibrant yellow */
  .event-figure::before {
    content: '';
    position: absolute;
    z-index: -1;
    inset: -11px -13px -13px -8px;
    border: 2.5px solid var(--crayon-1);
    border-radius: 22px 16px 20px 18px;
    transform: rotate(-1.2deg);
    opacity: 0.85;
    filter: var(--crayon-filter);
    pointer-events: none;
  }

  .event-figure::after {
    content: '';
    position: absolute;
    z-index: -1;
    inset: -5px -6px -6px -4px;
    border: 2px solid var(--crayon-2);
    border-radius: 16px 20px 15px 22px;
    transform: rotate(0.9deg);
    opacity: 0.65;
    filter: var(--crayon-filter);
    pointer-events: none;
  }

  .event-figure img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    border-radius: 14px;
    border: 5px solid var(--white);
    box-shadow: var(--shadow-md);
    transform: rotate(-1deg);
    transition: transform 0.45s var(--ease-spring);
  }

  .event-figure:hover img {
    transform: rotate(0deg) scale(1.01);
  }

  @media (prefers-reduced-motion: reduce) {
    .event-figure img {
      transition: none;
    }
  }

  .event-date {
    margin: 0 0 0.75rem;
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-style: italic;
    color: var(--tropical-coral);
  }

  .event-copy h2 {
    font-family: var(--font-script);
    font-size: clamp(2rem, 3.8vw, 2.7rem);
    font-weight: 400;
    letter-spacing: 0.01em;
    line-height: 1.15;
    margin-bottom: 1rem;
    max-width: 18ch;
  }

  .event-copy > p:not(.section-label):not(.event-date) {
    max-width: 40ch;
    margin-bottom: 1.75rem;
  }

  @media (max-width: 900px) {
    .event-layout { grid-template-columns: minmax(0, 1fr); }
    .event-figure { order: -1; }
    .event-copy h2 { max-width: none; }
  }
</style>
